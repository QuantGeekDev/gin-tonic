# Jihn Environment Example
# Keep secrets out of source control. This file documents all supported knobs.

# ===== LLM =====
JIHN_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=<your_anthropic_key>
ANTHROPIC_MODEL=claude-sonnet-4-6
# Runtime alias profile: default | sonnet | haiku
JIHN_LLM_MODEL_ALIAS=default
# Optional per-alias model IDs
JIHN_ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
JIHN_ANTHROPIC_MODEL_HAIKU=claude-3-5-haiku-latest

# Alternative provider (uncomment to use OpenAI instead)
# JIHN_LLM_PROVIDER=openai
# OPENAI_API_KEY=<your_openai_key>
# OPENAI_MODEL=gpt-4.1
# For Anthropic:
# JIHN_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=<your_anthropic_key>
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# Optional global model override:
# JIHN_LLM_MODEL=

# ===== Storage =====
# file | postgres
JIHN_STORAGE_BACKEND=postgres
DATABASE_URL=postgres://jihn:jihn@127.0.0.1:5433/jihn
# JIHN_DATABASE_URL=postgres://jihn:jihn@127.0.0.1:5433/jihn

# ===== Gateway =====
JIHN_GATEWAY_HOST=127.0.0.1
JIHN_GATEWAY_PORT=18789
JIHN_GATEWAY_URL=ws://127.0.0.1:18789/ws
JIHN_GATEWAY_TOKENS=dev-gateway-token

JIHN_GATEWAY_MAX_CONCURRENCY=4
JIHN_GATEWAY_MAIN_LANE_CONCURRENCY=4

JIHN_GATEWAY_RATE_LIMIT_REQUESTS=120
JIHN_GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# Persisted allowlisted runtime settings
JIHN_SETTINGS_FILE=.jihn/runtime-settings.json

# ===== Agent runtime =====
JIHN_AGENT_ID=main
JIHN_SESSION_SCOPE=channel-peer
JIHN_CONTEXT_TOKEN_BUDGET=8000
JIHN_CONTEXT_TARGET_TOKEN_BUDGET=6400
JIHN_TOOL_POLICY_MODE=allow
JIHN_TOOL_POLICY_TOOLS=
JIHN_MCP_SERVERS=[]
JIHN_MCP_CACHE_TTL_MS=30000
JIHN_BASE_URL=http://localhost:3000

# ===== Telegram =====
JIHN_TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>
JIHN_TELEGRAM_TRANSPORT=polling
JIHN_TELEGRAM_AGENT_ID=main
JIHN_TELEGRAM_SCOPE=channel-peer
JIHN_TELEGRAM_MAX_TURNS=20
JIHN_TELEGRAM_MAX_TOKENS=1024
JIHN_TELEGRAM_REPLY_TO_INCOMING=true
JIHN_TELEGRAM_TYPING_ENABLED=true
JIHN_TELEGRAM_TYPING_INTERVAL_MS=4000
# Optional chat allow-list
# JIHN_TELEGRAM_ALLOWED_CHAT_IDS=123456,-987654

# Durable outbox queue
JIHN_TELEGRAM_OUTBOX_BACKEND=postgres
JIHN_TELEGRAM_OUTBOUND_MAX_ATTEMPTS=4
JIHN_TELEGRAM_OUTBOUND_BASE_DELAY_MS=250

# Debug/state files
JIHN_TELEGRAM_DEBUG_FILE=.jihn/telegram-debug.json
JIHN_TELEGRAM_DEBUG_MAX_EVENTS=120

# Channel pairing auth
JIHN_CHANNEL_AUTH_MODE=off
JIHN_CHANNEL_AUTH_STORE_FILE=.jihn/channel-auth.json
# JIHN_CHANNEL_AUTH_SECRET=<secret>
JIHN_CHANNEL_AUTH_CODE_LENGTH=6
JIHN_CHANNEL_AUTH_CODE_TTL_MS=300000
JIHN_CHANNEL_AUTH_MAX_ATTEMPTS=5

# Webhook transport settings (required when transport=webhook)
# JIHN_TELEGRAM_WEBHOOK_PUBLIC_BASE_URL=https://bot.example.com
# JIHN_TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# JIHN_TELEGRAM_WEBHOOK_SECRET=<webhook_secret>
# JIHN_TELEGRAM_WEBHOOK_HOST=0.0.0.0
# JIHN_TELEGRAM_WEBHOOK_PORT=8787

# Telegram Prometheus endpoint
JIHN_TELEGRAM_METRICS_ENABLED=true
JIHN_TELEGRAM_METRICS_HOST=127.0.0.1
JIHN_TELEGRAM_METRICS_PORT=18792
JIHN_TELEGRAM_METRICS_PATH=/metrics

# ===== Web API auth/rate limiting =====
JIHN_API_AUTH_ENABLED=0
JIHN_API_ALLOWED_ORIGINS=http://localhost:3000
JIHN_API_TOKENS=dev-web-token|agent:read;agent:write;mcp:read;mcp:write;memory:read;memory:write|global
JIHN_API_RATE_LIMIT_WINDOW_MS=60000
JIHN_API_RATE_LIMIT_MAX_REQUESTS=120
