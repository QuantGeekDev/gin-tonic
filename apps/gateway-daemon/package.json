{
  "name": "jihn-gateway-daemon",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "npm run build --workspace=@jihn/agent-core && npm run build --workspace=@jihn/gateway-client",
    "build": "tsc",
    "dev": "tsx --env-file=.env --watch src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "test": "npm run build && NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@jihn/agent-core": "file:../../packages/agent-core",
    "@jihn/gateway-client": "file:../../packages/gateway-client",
    "prom-client": "^15.1.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "jest": "^30.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
